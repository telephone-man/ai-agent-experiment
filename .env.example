# Local demo environment template.
# setup.sh copies this to .env and generates a shell-safe conf/env from it.
# .env is ignored and is the reviewer-facing Docker Compose override file.
# Do not commit real API keys or local network changes.

VOIPNET_DRIVER=bridge
VOIPNET_SUBNET=192.168.144.0/20

VOICE_GATEWAY_LOCAL_IP=192.168.144.2
KAMAILIO_DB_LOCAL_IP=192.168.144.3
KAMAILIO_LOCAL_IP=192.168.144.4
RTPENGINE_LOCAL_IP=192.168.144.5
FREESWITCH_LOCAL_IP=192.168.144.6
STT_SERVICE_LOCAL_IP=192.168.144.7
LLM_SERVICE_LOCAL_IP=192.168.144.8
TTS_SERVICE_LOCAL_IP=192.168.144.9
WEB_CLIENT_LOCAL_IP=192.168.144.12

KAMAILIO_DB_HOSTNAME=kamailio_db
KAMAILIO_DB_NAME=kamailio
KAMAILIO_DB_SUPERUSER=kamailio
KAMAILIO_DB_SUPERUSER_PASS=
KAMAILIO_DB_RW_USER=kamailio_rw
KAMAILIO_DB_RW_PASS=
KAMAILIO_DB_RO_USER=kamailio_ro
KAMAILIO_DB_RO_PASS=

FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=
FREESWITCH_EXTERNAL_DTMF_TYPE=rfc2833

KAMAILIO_LISTEN_IP=0.0.0.0
KAMAILIO_ADVERTISED_IP=127.0.0.1
KAMAILIO_EXTERNAL_SIP_PORT=5067
KAMAILIO_EXTERNAL_ADVERTISED_PORT=5060
KAMAILIO_EXTERNAL_WEBRTC_PORT=5066
KAMAILIO_INTERNAL_SIP_PORT=5060
KAMAILIO_INTERNAL_WEBRTC_PORT=5068
KAMAILIO_DEBUG_LEVEL=0
KAMAILIO_SIP_BODY_LOGGING=0
KAMAILIO_SIPDUMP_ENABLE=0
KAMAILIO_SIPTRACE_ENABLE=0

RTPENGINE_RTP_PORT_START=30000
RTPENGINE_RTP_PORT_END=30200
RTPENGINE_LISTEN_CLI_IP=127.0.0.1
RTPENGINE_INTERFACE_EXTERNAL_ADVERTISE_IP=127.0.0.1
RTPENGINE_LOG_LEVEL=6
RTPENGINE_LOG_LEVEL_SUBSYSTEM=core:6;control:6;crypto:6;srtp:6;rtcp:6;ice:6;internals:0

# Default to live provider behavior. Set AI_OFFLINE_FALLBACK=1 only for offline demos/tests.
AI_OFFLINE_FALLBACK=0
OPENAI_API_KEY=
STT_FALLBACK_ON_UPSTREAM_ERROR=0
LLM_FALLBACK_ON_UPSTREAM_ERROR=0

OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_LLM_MODEL=gpt-5-mini
OPENAI_TRANSLATION_MODEL=gpt-5-nano
OPENAI_TRANSLATION_MAX_OUTPUT_TOKENS=96
OPENAI_TRANSLATION_REASONING_EFFORT=minimal
OPENAI_TRANSLATION_VERBOSITY=low
OPENAI_LLM_MAX_RESPONSE_WORDS=35
OPENAI_LLM_MAX_OUTPUT_TOKENS=160
OPENAI_LLM_HISTORY_MESSAGES=6
OPENAI_LLM_REASONING_EFFORT=minimal
LLM_FAST_PATH_RESPONSES=0
# Explicit opt-in for the README weather walkthrough's local tool-wait demo.
LLM_ENABLE_MOCK_WEATHER_TOOL=0
MOCK_WEATHER_TOOL_DELAY_MS=900
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime?intent=transcription
OPENAI_STT_TURN_DETECTION_TYPE=server_vad
OPENAI_STT_SEMANTIC_EAGERNESS=auto
OPENAI_STT_PROMPT=
OPENAI_STT_INCLUDE_LOGPROBS=0
OPENAI_STT_VAD_THRESHOLD=0.5
OPENAI_STT_PREFIX_PADDING_MS=300
OPENAI_STT_SILENCE_DURATION_MS=500
OPENAI_STT_NOISE_REDUCTION_TYPE=near_field
VOICE_GATEWAY_SPEECH_START_BARGE_IN_ENABLED=0
STT_SUPPRESS_LOW_AUDIO_FINALS=1
STT_FINAL_SPEECH_RMS_THRESHOLD=250
STT_FINAL_MIN_SPEECH_MS=120
STT_FINAL_MIN_AVG_RMS=250
STT_FINAL_MIN_PEAK_RMS=400
# Optional deterministic STT output for offline smoke runs. Keep confidence at 0
# unless you intentionally want local fake audio to drive downstream AI paths.
LOCAL_STT_FINAL_TEXT=Speech detected by offline STT fallback; no transcript available.
LOCAL_STT_CONFIDENCE=0

STT_SERVICE_URL=http://stt_service:8001
LLM_SERVICE_URL=http://llm_service:8002
TTS_SERVICE_URL=http://tts_service:8003
VOICE_GATEWAY_MEDIA_URL=ws://voice-gateway:8000/media

# Provider timeouts and per-provider concurrency limits for the voice gateway.
VOICE_GATEWAY_STT_CONNECT_TIMEOUT_SECONDS=10
VOICE_GATEWAY_LLM_TIMEOUT_SECONDS=60
VOICE_GATEWAY_TRANSLATION_TIMEOUT_SECONDS=60
VOICE_GATEWAY_TTS_TIMEOUT_SECONDS=30
VOICE_GATEWAY_PROVIDER_ACQUIRE_TIMEOUT_SECONDS=2
VOICE_GATEWAY_STT_MAX_CONCURRENCY=16
VOICE_GATEWAY_LLM_MAX_CONCURRENCY=8
VOICE_GATEWAY_TRANSLATION_MAX_CONCURRENCY=8
VOICE_GATEWAY_TTS_MAX_CONCURRENCY=16

# Local demo safety limits for concurrent calls and temporary provider failures.
VOICE_GATEWAY_MAX_ACTIVE_SESSIONS=4
VOICE_GATEWAY_CIRCUIT_FAILURE_THRESHOLD=3
VOICE_GATEWAY_CIRCUIT_RESET_SECONDS=30
VOICE_TURN_HOLD_CLARIFY_MS=1500
VOICE_GATEWAY_DELIVERY_RESUME_DELAY_SECONDS=2.0
VOICE_GATEWAY_ALLOW_WILDCARD_EVENTS=0
# Optional explicit bind; blank defaults to VOICE_GATEWAY_LOCAL_IP.
VOICE_GATEWAY_ESL_HOST=

FREESWITCH_HOST=freeswitch
FREESWITCH_CONSOLE_LOGLEVEL=notice
FREESWITCH_CORE_LOGLEVEL=notice

# Default TTS command used by FreeSWITCH, with a flite fallback.
FREESWITCH_TTS_ENGINE=piper
FREESWITCH_TTS_VOICE=en
FREESWITCH_TTS_ALT_ENGINE=flite
FREESWITCH_TTS_ALT_VOICE=kal

# Piper voices are mapped by language in freeswitch/conf/autoload_configs/piper_tts.conf.xml.
FREESWITCH_TTS_ENGINE_EN=piper
FREESWITCH_TTS_VOICE_EN=en
FREESWITCH_TTS_ENGINE_FR=piper
FREESWITCH_TTS_VOICE_FR=fr

# Translation demo target and retry controls.
TRANSLATION_DEFAULT_PEER_AOR=sip:bob@voice.local
TRANSLATION_KAMAILIO_FS_PATH=sip:kamailio:5060
TRANSLATION_PEER_STREAM_ATTEMPTS=12
TRANSLATION_PEER_STREAM_RETRY_SECONDS=1

LOG_LEVEL=INFO
